{
  "name": "apartment-laundry-classifier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "classify": "bun run src/classify-image.ts",
    "eval:fixtures": "bun run scripts/evaluate-fixtures.ts",
    "eval:listings": "bun run scripts/evaluate-listings.ts",
    "eval:listing-summaries": "bun run scripts/evaluate-listing-summaries.ts",
    "fair:listings": "bun run scripts/run-fair-listing-run.ts",
    "summary:listings": "bun run scripts/run-listing-summaries.ts",
    "find": "bun run scripts/search-listings.ts",
    "scan": "bun run scripts/scan-listings.ts",
    "search": "bun run scripts/search-listings.ts",
    "report": "bun run scripts/evidence-report.ts",
    "smoke:extractions": "bun run scripts/smoke-listing-extraction.ts",
    "smoke:search": "bun run scripts/smoke-search-discovery.ts",
    "smoke:browser": "bun run scripts/smoke-playwright.ts",
    "smoke:browser:sites": "bun run scripts/smoke-browser-sites.ts",
